// Inklings — Prisma schema
// Adapted from the Inklings handoff doc and the spine §11 baseline.
// Tenancy model: each parent (User) is their own tenant. Children belong to one parent.
// All child-facing rows scope by parent_id via cascade.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === Parents (the actual users) ===
model User {
  id                 String         @id @default(cuid())
  email              String         @unique
  name               String?
  stripeCustomerId   String?        @unique
  subscriptionTier   String         @default("free") // free | premium
  subscriptionStatus String?
  premiumUntil       DateTime?
  printCredits       Int            @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  children           ChildProfile[]
  sessions           Session[]
  magicLinks         MagicLink[]
  orders             Order[]
  giftCodesRedeemed  GiftCode[]     @relation("GiftRedeemer")
}

// === Magic-link auth ===
model MagicLink {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// === Child profiles ===
model ChildProfile {
  id        String      @id @default(cuid())
  parentId  String
  parent    User        @relation(fields: [parentId], references: [id], onDelete: Cascade)
  name      String
  age       Int
  avatarUrl String?
  activeSeriesId String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  characters Character[]
  worlds     World[]
  series     Series[]
  books      Book[]

  @@index([parentId])
}

// === Character Bible ===
model Character {
  id                 String   @id @default(cuid())
  childId            String
  child              ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  name               String
  nickname           String?
  pronouns           String?
  role               String?
  species            String?
  colorsJson         Json?
  outfit             String?
  bodyShape          String?
  accessoriesJson    Json?
  expressionStyle    String?
  personalityTraits  Json?
  relationshipsJson  Json?
  favoriteActivities Json?
  recurringPhrases   Json?
  storyArcs          Json?
  imageSeed          String?
  loraRef            String?
  approvedImagesJson Json?
  sandboxMode        Boolean  @default(true)
  parentApprovedAt   DateTime?
  firstAppearance    DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  seriesCast SeriesCast[]

  @@index([childId])
}

// === Worlds ===
model World {
  id              String   @id @default(cuid())
  childId         String
  child           ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  locationsJson   Json?
  visualTheme     String?
  recurringObjectsJson Json?
  weather         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  series Series[]

  @@index([childId])
}

// === Series ===
model Series {
  id          String   @id @default(cuid())
  childId     String
  child       ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  worldId     String?
  world       World?   @relation(fields: [worldId], references: [id])
  title       String
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  books      Book[]
  seriesCast SeriesCast[]

  @@index([childId])
}

// === Books ===
model Book {
  id              String   @id @default(cuid())
  seriesId        String?
  series          Series?  @relation(fields: [seriesId], references: [id])
  childId         String
  child           ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  title           String
  subtitle        String?
  status          String   @default("draft") // draft | awaiting_parent | approved | exported | ordered
  storyJson       Json?
  coverUrl        String?
  pdfDraftUrl     String?
  pdfFinalUrl     String?
  kdpReady        Boolean  @default(false)
  parentApprovedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  pages  BookPage[]
  orders Order[]

  @@index([childId])
}

model BookPage {
  id             String   @id @default(cuid())
  bookId         String
  book           Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  pageNumber     Int
  act            String
  textContent    String
  imagePrompt    String?
  imageUrlLowres String?
  imageUrlHd     String?
  imageApproved  Boolean  @default(false)
  layoutTemplate String   @default("centered")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([bookId, pageNumber])
  @@index([bookId])
}

// === Orders ===
model Order {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id])
  bookId                String
  book                  Book     @relation(fields: [bookId], references: [id])
  stripePaymentIntent   String?  @unique
  quantity              Int      @default(1)
  unitPriceCents        Int
  status                String   @default("pending") // pending | paid | paid_needs_shipping | fulfilled | refunded
  kdpUploadInitiatedAt  DateTime? // legacy; unused — Lulu is the print partner
  luluJobId             String?
  luluStatus            String?
  printSubmittedAt      DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@index([bookId])
}

// === Gift Premium codes ===
model GiftCode {
  id               String    @id @default(cuid())
  code             String    @unique
  plan             String
  months           Int
  purchaserEmail   String
  recipientEmail   String?
  stripeSessionId  String?   @unique
  redeemedByUserId String?
  redeemedBy       User?     @relation("GiftRedeemer", fields: [redeemedByUserId], references: [id])
  redeemedAt       DateTime?
  expiresAt        DateTime
  createdAt        DateTime  @default(now())

  @@index([purchaserEmail])
}

// === COPPA parental consent (captured at trial signup) ===
model ParentalConsent {
  id          String   @id @default(cuid())
  userId      String
  email       String
  consentText String
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([email])
}

// === Quota ledger (free-tier rate limiting) ===
model UsageEvent {
  id        String   @id @default(cuid())
  userId    String
  kind      String   // story_started | image_generated | pdf_exported
  meta      Json?
  createdAt DateTime @default(now())

  @@index([userId, kind, createdAt])
}

model SeriesCast {
  id          String    @id @default(cuid())
  seriesId    String
  series      Series    @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  slot        Int
  role        String    @default("core")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([seriesId, slot])
  @@unique([seriesId, characterId])
  @@index([seriesId])
  @@index([characterId])
}

{
  "name": "inklings",
  "version": "0.1.0",
  "private": true,
  "description": "Inklings — AI-guided storybook studio for kids ages 4-8. Spawned from the SolutionStore SaaS spine.",
  "scripts": {
    "dev": "next dev -p 3400",
    "build": "npx prisma generate && next build",
    "start": "next start -p 3400",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "playwright:install": "playwright install chromium",
    "e2e": "playwright test",
    "kdp:sample": "tsx scripts/generate_sample_kdp.ts",
    "marketing:showcase": "tsx scripts/build-marketing-showcase.ts",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "npx tsx prisma/seed.ts",
    "walkthrough:record": "node scripts/record_walkthrough.cjs"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/client": "^6.8.2",
    "bcryptjs": "^2.4.3",
    "jose": "^5.10.0",
    "lucide-react": "^0.439.0",
    "next": "^15.0.3",
    "nodemailer": "^6.9.16",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "stripe": "^17.3.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.7.5",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint-config-next": "^15.0.3",
    "postcss": "^8.4.49",
    "prisma": "^6.8.2",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
